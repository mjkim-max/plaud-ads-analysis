# 이 파일을 복사해 `.streamlit/secrets.toml` 로 만들고 실제 값을 채운다.
# 실제 secrets.toml 은 .gitignore 로 제외됨. (Community Cloud 는 앱 설정의 Secrets UI 에 붙여넣기)

[meta]
app_id = ""
app_secret = ""
access_token = ""      # 장수명 시스템 유저 토큰
ad_account_id = ""     # act_XXXXXXXXXX

[google_ads]
developer_token = ""
client_id = ""
client_secret = ""
refresh_token = ""
login_customer_id = "" # MCC ID (하이픈 없이)
customer_id = ""

[sales]
# 자사몰 / 네이버 / 쿠팡 API 키 (플랫폼 확정 후 채움)
platform = ""          # cafe24 / shopify / etc.
api_key = ""
api_secret = ""

[bigquery]
project_id = ""
dataset = ""
# service account JSON 은 Community Cloud Secrets 에 [gcp_service_account] 블록으로 별도 등록
